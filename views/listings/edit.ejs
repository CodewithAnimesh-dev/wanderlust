<% layout("/layouts/boilerplate.ejs") %>

<div class="row mt-3">
    <div class="col-8 offset-2">

        <h3>Edit your Listing</h3>

        <form method="POST"
              action="/listings/<%= listing._id %>?_method=PUT"
              novalidate
              class="needs-validation"
              enctype="multipart/form-data">

            <!-- TITLE -->
            <div class="mb-3">
                <label class="form-label">Title</label>
                <input
                    name="listing[title]"
                    value="<%= listing.title %>"
                    type="text"
                    class="form-control"
                    required>
            </div>

            <!-- DESCRIPTION -->
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea
                    name="listing[description]"
                    class="form-control"
                    required><%= listing.description %></textarea>
            </div>

            <!-- CURRENT IMAGE -->
            <div class="mb-3">
                <label class="form-label">Current Image</label>
                <br>
                <img
                    src="<%= originalImageUrl %>"
                    alt="Listing Image"
                    style="width:250px;height:180px;object-fit:cover;border-radius:10px;">
            </div>

            <!-- NEW IMAGE -->
            <div class="mb-3">
                <label class="form-label">Upload New Image</label>
                <input
                    name="listing[image]"
                    type="file"
                    class="form-control">
            </div>

            <!-- PRICE + COUNTRY -->
            <div class="row">
                <div class="mb-3 col-md-4">
                    <label class="form-label">Price</label>
                    <input
                        name="listing[price]"
                        value="<%= listing.price %>"
                        type="number"
                        class="form-control"
                        required>
                </div>

                <div class="mb-3 col-md-8">
                    <label class="form-label">Country</label>
                    <input
                        name="listing[country]"
                        value="<%= listing.country %>"
                        type="text"
                        class="form-control"
                        required>
                </div>
            </div>

            <!-- LOCATION -->
            <div class="mb-3">
                <label class="form-label">Location</label>
                <input
                    name="listing[location]"
                    value="<%= listing.location %>"
                    type="text"
                    class="form-control"
                    required>
            </div>

            <!-- CATEGORIES -->
            <div class="mb-3">
                <label class="form-label">Categories</label>

                <select
                    id="categorySelect"
                    name="listing[category][]"
                    multiple
                    class="form-control">

                    <option value="Trending"
                        <%= listing.category && listing.category.includes("Trending") ? "selected" : "" %>>
                        Trending
                    </option>

                    <option value="Iconic Cities"
                        <%= listing.category && listing.category.includes("Iconic Cities") ? "selected" : "" %>>
                        Iconic Cities
                    </option>

                    <option value="Mountains"
                        <%= listing.category && listing.category.includes("Mountains") ? "selected" : "" %>>
                        Mountains
                    </option>

                    <option value="Amazing Pools"
                        <%= listing.category && listing.category.includes("Amazing Pools") ? "selected" : "" %>>
                        Amazing Pools
                    </option>

                    <option value="Camping"
                        <%= listing.category && listing.category.includes("Camping") ? "selected" : "" %>>
                        Camping
                    </option>

                    <option value="Farms"
                        <%= listing.category && listing.category.includes("Farms") ? "selected" : "" %>>
                        Farms
                    </option>

                    <option value="Castles"
                        <%= listing.category && listing.category.includes("Castles") ? "selected" : "" %>>
                        Castles
                    </option>

                    <option value="Domes"
                        <%= listing.category && listing.category.includes("Domes") ? "selected" : "" %>>
                        Domes
                    </option>

                    <option value="Boating"
                        <%= listing.category && listing.category.includes("Boating") ? "selected" : "" %>>
                        Boating
                    </option>

                </select>
            </div>

            <button class="btn btn-dark edit-btn mt-3">
                Save Changes
            </button>

        </form>

    </div>
</div>

<script>
new TomSelect("#categorySelect", {
    plugins: ["remove_button"],
    placeholder: "Select Categories",
    create: false,
    maxItems: null
});
</script>